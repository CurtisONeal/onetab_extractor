# =============================================================================
# OneTab Extractor Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# Platform override (optional — auto-detected if left blank)
# Valid values: mac, linux, windows
PLATFORM=

# OneTab LevelDB source path (optional — uses platform default if left blank)
#
# macOS default:
#   ~/Library/Application Support/Google/Chrome/Default/Local Extension Settings/chphlpgkkbolifaimnlloiipkdnihall
#
# Linux default:
#   ~/.config/google-chrome/Default/Local Extension Settings/chphlpgkkbolifaimnlloiipkdnihall
#
# Windows default:
#   %LOCALAPPDATA%\Google\Chrome\User Data\Default\Local Extension Settings\chphlpgkkbolifaimnlloiipkdnihall
#
ONETAB_PATH=

# Output directory for the exported CSV (optional — defaults to current working directory)
OUTPUT_DIR=
