# =============================================================================
# OneTab Extractor Configuration
# Copy this file to .env and fill in values for your environment.
# All values are optional — sensible defaults are auto-detected per platform.
# =============================================================================

# Platform override (optional — auto-detected from sys.platform if left blank)
# Valid values: mac, linux, windows
PLATFORM=

# Chrome user data directory (optional — uses platform default if left blank)
#
# macOS default:   ~/Library/Application Support/Google/Chrome
# Linux default:   ~/.config/google-chrome
# Windows default: %LOCALAPPDATA%\Google\Chrome\User Data
#
CHROME_DIR=

# Override for a single explicit OneTab LevelDB path (optional).
# When set, --all-profiles is ignored and only this path is read.
#
# macOS example:
#   ONETAB_PATH=~/Library/Application Support/Google/Chrome/Profile 1/Local Extension Settings/chphlpgkkbolifaimnlloiipkdnihall
#
ONETAB_PATH=

# Output directory for the exported CSV (optional — defaults to current working directory)
OUTPUT_DIR=
